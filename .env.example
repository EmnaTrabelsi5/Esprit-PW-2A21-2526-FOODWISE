# Configuration base de données
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=foodwise
DB_USER=root
DB_PASS=

# Configuration SMTP Gmail
# IMPORTANT: Pour Gmail, utilisez une "App password" et non votre mot de passe régulier
# https://support.google.com/accounts/answer/185833
MAIL_USERNAME=votre-email@gmail.com
MAIL_PASSWORD=votre-app-password-16-caracteres

# Configuration du mailer (optionnel, par défaut utilise Gmail SMTP)
MAIL_FROM_NAME=FoodWise
MAIL_FROM_EMAIL=votre-email@gmail.com
